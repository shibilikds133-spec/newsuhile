    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.8",
    "puppeteer": "^25.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-qrcode": "^0.4.1",
    "wait-on": "^9.0.4"
