{
  "name": "dawa-trust",
  "private": true,
  "version": "1.0.0",
  "description": "Office Management Dashboard",
  "author": "Dawa Trust",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:desktop": "vite build --config vite.config.desktop.js",
    "pack": "npm run build:desktop && electron-packager . \"Dawa Trust Dashboard\" --platform=win32 --arch=x64 --out=dist_desktop --overwrite --icon=public/image/logo.png",
    "dist:win": "npm run build:desktop && electron-builder build --win",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.30.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
